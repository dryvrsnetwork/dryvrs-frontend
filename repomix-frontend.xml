"use client";

import { useWriteContract } from 'wagmi';
import { parseUnits, erc20Abi } from 'viem';
import { RIDE_ESCROW_ADDRESS, MOCK_USDC_ADDRESS, RIDE_ESCROW_ABI } from '../constants/contracts';

export default function EscrowButton() {
  const { writeContractAsync } = useWriteContract();

  const handleAgreeAndLock = async (agreedPrice: string) => {
    try {
      // 1. Convert the agreed $15 into blockchain math (18 decimals for our Mock USDC)
      const amountToLock = parseUnits(agreedPrice, 18);

      // 2. Step One: Approve the Escrow Contract to pull the Mock USDC
      console.log("Approving USDC...");
      await writeContractAsync({
        address: MOCK_USDC_ADDRESS,
        abi: erc20Abi,
        functionName: 'approve',
        args: [RIDE_ESCROW_ADDRESS, amountToLock],
      });

      // 3. Step Two: Execute the Pull and Lock the funds in Escrow
      console.log("Locking funds in Escrow...");
      await writeContractAsync({
        address: RIDE_ESCROW_ADDRESS,
        abi: RIDE_ESCROW_ABI,
        functionName: 'requestRide',
        args: [MOCK_USDC_ADDRESS, amountToLock],
      });

      alert("Ride funds successfully locked in Escrow!");
      
    } catch (error) {
      console.error("Escrow failed:", error);
    }
  };

  return (
    <button 
      onClick={() => handleAgreeAndLock("15")} 
      className="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg shadow-md transition-all"
    >
      Agree to $15 & Lock Funds
    </button>
  );
}

<file path="hooks/useBidding.ts">
import { useState, useEffect } from 'react';
import { supabase } from '../utils/supabase';

export function useBidding(rideId: string) {
  const [bids, setBids] = useState<any[]>([]);

  useEffect(() => {
    if (!rideId) return;

    const fetchBids = async () => {
      const { data } = await supabase
        .from('active_bids')
        .select('*')
        .eq('ride_id', rideId)
        .eq('status', 'PENDING');
      if (data) setBids(data);
    };

    fetchBids();

    const subscription = supabase
      .channel('bids_channel')
      .on('postgres_changes', { event: '*', schema: 'public', table: 'active_bids', filter: `ride_id=eq.${rideId}` }, 
        (payload) => {
          fetchBids();
        }
      )
      .subscribe();

    return () => { supabase.removeChannel(subscription); };
  }, [rideId]);

  const submitBid = async (riderWallet: string, driverWallet: string, amount: number) => {
    const { error } = await supabase.from('active_bids').insert([{
      ride_id: rideId,
      rider_wallet: riderWallet,
      driver_wallet: driverWallet,
      bid_amount: amount,
      status: 'PENDING'
    }]);
    if (error) console.error("Transmission failed:", error);
  };

  const acceptBid = async (bidId: string) => {
    await supabase.from('active_bids').update({ status: 'ACCEPTED' }).eq('id', bidId);
    await supabase.from('active_bids').update({ status: 'REJECTED' }).eq('ride_id', rideId).neq('id', bidId);
  };

  const cancelBid = async (bidId: string) => {
    const { error } = await supabase.from('active_bids').delete().eq('id', bidId);
    if (error) console.error("Failed to cancel transmission:", error);
  };

  return { bids, submitBid, acceptBid, cancelBid };
}

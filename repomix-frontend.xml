import { http, createConfig } from 'wagmi'
import { foundry } from 'wagmi/chains'
import { injected } from 'wagmi/connectors'

export const config = createConfig({
  chains: [foundry],
  connectors: [injected()], // 🔌 Force MetaMask priority
  transports: {
    [foundry.id]: http('http://127.0.0.1:8545'), // 📡 Hard-locked to Anvil
  },
  ssr: true, // 🛑 Prevents Next.js hydration crashes
})

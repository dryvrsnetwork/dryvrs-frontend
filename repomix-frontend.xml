<file path="hooks/useBidding.ts">
import { useState, useEffect } from 'react';
import { supabase } from '../utils/supabaseClient';

export function useBidding(rideId: string) {
    const [bids, setBids] = useState<any[]>([]);

    useEffect(() => {
        // Don't fetch if the rideId is empty or invalid
        if (!rideId || rideId === "0" || isNaN(Number(rideId))) {
            setBids([]);
            return;
        }

        const fetchBids = async () => {
            const { data, error } = await supabase
                .from('bids')
                .select('*')
                .eq('ride_id', rideId)
                .eq('status', 'PENDING') // Only show active haggling offers
                .order('bid_amount', { ascending: true }); // Lowest bids show up first

            if (error) {
                console.error("Radar Error: Failed to fetch bids", error);
            } else if (data) {
                setBids(data);
            }
        };

        // Initial sweep
        fetchBids();

        // 📡 UPLINK ACTIVE: Subscribe to real-time WebSockets
        const channel = supabase
            .channel(`public:bids:ride_id=eq.${rideId}`)
            .on('postgres_changes', { 
                event: '*', 
                schema: 'public', 
                table: 'bids',
                filter: `ride_id=eq.${rideId}`
            }, (payload) => {
                // When any bid is added, updated, or deleted on this ride, refresh the radar
                fetchBids();
            })
            .subscribe();

        // Cleanup the subscription when the component unmounts or rideId changes
        return () => {
            supabase.removeChannel(channel);
        };
    }, [rideId]);

    const submitBid = async (riderWallet: string, driverWallet: string, amount: number) => {
        // 1. Zero-Friction Profile Creation (Upsert)
        // If the driver doesn't exist in dryvr_profiles, create them invisibly.
        await supabase.from('dryvr_profiles').upsert([
            { wallet_address: driverWallet, role: 'driver' }
        ], { onConflict: 'wallet_address' });

        // 2. Lock the math to 2 decimals and fire the bid into the database
        const cleanAmount = Number(amount.toFixed(2));

        const { error } = await supabase.from('bids').insert([{
            ride_id: rideId,
            driver_wallet: driverWallet,
            bid_amount: cleanAmount
        }]);
        
        if (error) {
            console.error("Transmission Failed: Error submitting bid:", error);
            throw error; // Throw so the UI can catch and alert the user
        }
    };

    const acceptBid = async (bidId: string) => {
        // 1. Mark the winning bid as ACCEPTED
        const { error: acceptError } = await supabase
            .from('bids')
            .update({ status: 'ACCEPTED' })
            .eq('id', bidId);
            
        if (acceptError) {
            console.error("Failed to accept bid:", acceptError);
            throw acceptError;
        }
        
        // 2. Clean up the radar: Mark all other bids for this ride as REJECTED
        await supabase
            .from('bids')
            .update({ status: 'REJECTED' })
            .eq('ride_id', rideId)
            .neq('id', bidId);
    };

    const cancelBid = async (bidId: string) => {
        // Used by Dryvrs to retract an offer, or Rydrs to manually clear a bad offer from their screen
        const { error } = await supabase
            .from('bids')
            .update({ status: 'CANCELLED' })
            .eq('id', bidId);
            
        if (error) {
            console.error("Failed to cancel bid:", error);
            throw error;
        }
    };

    return { bids, submitBid, acceptBid, cancelBid };
}

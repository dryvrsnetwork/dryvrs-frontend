import { useState, useEffect } from 'react';
import { supabase } from '../utils/supabaseClient';

export function useRadar() {
    const [activeRides, setActiveRides] = useState<any[]>([]);

    useEffect(() => {
        const fetchRadarPings = async () => {
            const { data, error } = await supabase
                .from('active_rides')
                .select('*')
                .eq('status', 'PENDING') // Only pull rides that haven't been claimed yet
                .order('created_at', { ascending: false }); // Newest rides at the top

            if (!error && data) {
                setActiveRides(data);
            } else {
                console.error("Radar interference:", error);
            }
        };

        // Initial sweep when the driver turns on the HUD
        fetchRadarPings();

        // 📡 UPLINK ACTIVE: Listen for new riders dropping pins in real-time
        const channel = supabase
            .channel('public:active_rides')
            .on('postgres_changes', { event: '*', schema: 'public', table: 'active_rides' }, () => {
                fetchRadarPings();
            })
            .subscribe();

        // Turn off the antenna when the driver logs off
        return () => { 
            supabase.removeChannel(channel); 
        };
    }, []);

    return { activeRides };
}
